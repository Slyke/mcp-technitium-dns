# Copy this file to .env for local development and replace placeholder values.
# Do not commit .env with real tokens.

# MCP client authentication. Read tokens can call read-only tools only.
MCP_READ_BEARER_TOKENS=[{name:"reader1",token:"replace-read-token"}]

# Readwrite tokens can call mutating tools when READ_ONLY=false.
MCP_READWRITE_BEARER_TOKENS=[{name:"admin1",token:"replace-readwrite-token"}]

# Technitium DNS Server API token. API token is the only Technitium auth method used by this server.
TECHNITIUM_API_TOKEN=replace-technitium-api-token
# Prefer a protected token file in production:
# TECHNITIUM_API_TOKEN_FILE=./data/technitium-api.token

TECHNITIUM_BASE_URL=https://technitium.lan:53443
TECHNITIUM_TIMEOUT_MS=10000
TECHNITIUM_TLS_REJECT_UNAUTHORIZED=true

# HTTP targets are rejected unless this is true and the target host is local/private.
TECHNITIUM_ALLOW_HTTP_LOCAL=false
TECHNITIUM_ALLOW_HTTP_HOSTNAMES=

# MCP listener. HTTPS is enabled by default.
HTTPS_ENABLED=true
HTTPS_HOST=0.0.0.0
HTTPS_PORT=3443
HTTP_ENABLED=false
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Safety and behavior.
READ_ONLY=false
AUTH_HEALTHCHECKS=false
READY_CHECK_TECHNITIUM=false
INCLUDE_RAW_DEFAULT=false

# Local storage.
AUDIT_ENABLED=true
AUDIT_FILE=./data/audit.jsonl
AUDIT_RECORD_READS=false
AUDIT_MAX_ENTRIES=0
BACKUP_DIR=./data/backups
IMPORT_DIR=./data/imports
CERTS_DIR=./data/certs

# Rate limits.
RATE_LIMIT_READ_MAX=120
RATE_LIMIT_READ_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=30
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_DESTRUCTIVE_MAX=5
RATE_LIMIT_DESTRUCTIVE_WINDOW_MS=60000
